---
layout: base.njk
title: Contacto
permalink: /contacto/
descripcion: Contacta con la Fundación Discover Villajoyosa.
---
<div class="cabecera-pagina">
  <div class="contenedor">
    <p class="miga"><a href="/">Inicio</a> / Contacto</p>
    <h1>Contacto</h1>
    <p>¿Eres empresa turística, institución o medio de comunicación? Escríbenos y te responderemos lo antes posible.</p>
  </div>
</div>

<section class="seccion">
  <div class="contenedor contacto-grid">
    <div>
      <span class="etiqueta-seccion">Dónde estamos</span>
      <div class="dato-contacto mt-40">
        <p class="titulo-dato">Sede social</p>
        <p>{{ general.direccion }}</p>
      </div>
      {% if general.email %}
      <div class="dato-contacto">
        <p class="titulo-dato">Correo electrónico</p>
        <a href="mailto:{{ general.email }}">{{ general.email }}</a>
      </div>
      {% endif %}
      {% if general.telefono %}
      <div class="dato-contacto">
        <p class="titulo-dato">Teléfono</p>
        <a href="tel:{{ general.telefono | replace(' ', '') }}">{{ general.telefono }}</a>
      </div>
      {% endif %}
    </div>
    <div>
      {% if general.web3forms_key %}
      <form class="formulario" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="{{ general.web3forms_key }}">
        <input type="hidden" name="subject" value="Nuevo mensaje desde la web de la Fundación">
        <input type="hidden" name="redirect" id="campo-redirect" value="">
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off">
        <div class="campo">
          <label for="nombre">Nombre y apellidos</label>
          <input id="nombre" name="nombre" type="text" required>
        </div>
        <div class="campo">
          <label for="email">Correo electrónico</label>
          <input id="email" name="email" type="email" required>
        </div>
        <div class="campo">
          <label for="asunto">Asunto</label>
          <input id="asunto" name="asunto" type="text" required>
        </div>
        <div class="campo">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="6" required></textarea>
        </div>
        <button class="boton boton-principal" type="submit">Enviar mensaje</button>
        <script>document.getElementById("campo-redirect").value = location.origin + "/contacto/gracias/";</script>
      </form>
      {% else %}
      <form class="formulario" id="form-correo">
        <div class="campo">
          <label for="nombre">Nombre y apellidos</label>
          <input id="nombre" name="nombre" type="text" required>
        </div>
        <div class="campo">
          <label for="asunto">Asunto</label>
          <input id="asunto" name="asunto" type="text" required>
        </div>
        <div class="campo">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="6" required></textarea>
        </div>
        <button class="boton boton-principal" type="submit">Enviar mensaje</button>
        <p class="nota-formulario">Al pulsar «Enviar» se abrirá tu aplicación de correo con el mensaje ya preparado para {{ general.email }}.</p>
      </form>
      <script>
        document.getElementById("form-correo").addEventListener("submit", function (e) {
          e.preventDefault();
          var nombre = document.getElementById("nombre").value;
          var asunto = document.getElementById("asunto").value;
          var mensaje = document.getElementById("mensaje").value;
          var cuerpo = "Nombre: " + nombre + "\n\n" + mensaje;
          window.location.href = "mailto:{{ general.email }}" +
            "?subject=" + encodeURIComponent(asunto) +
            "&body=" + encodeURIComponent(cuerpo);
        });
      </script>
      {% endif %}
    </div>
  </div>
</section>
