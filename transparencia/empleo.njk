---
layout: base.njk
title: Ofertas de empleo
permalink: /transparencia/empleo/
descripcion: Ofertas públicas de empleo de la Fundación Discover Villajoyosa.
---
<div class="cabecera-pagina">
  <div class="contenedor">
    <p class="miga"><a href="/">Inicio</a> / <a href="/transparencia/">Transparencia</a> / Empleo</p>
    <h1>Ofertas de empleo</h1>
    <p>Convocatorias de puestos de trabajo de la Fundación, con sus bases, plazos y resoluciones.</p>
  </div>
  <div class="casas-mini" aria-hidden="true"><img src="/img/casas.svg" alt=""></div>
</div>

<section class="seccion">
  <div class="contenedor">
    {% if collections.empleoDesc.length %}
    <div class="lista-expedientes">
      {% for item in collections.empleoDesc %}
      <div class="expediente">
        <div class="expediente-cabecera">
          <div>
            <h3>{{ item.data.title }}</h3>
            <div class="meta">
              <span>Publicada: {{ item.date | fecha }}</span>
              {% if item.data.plazo %}<span>Plazo de presentación: hasta el {{ item.data.plazo | fecha }}</span>{% endif %}
            </div>
          </div>
          <span class="estado estado-{{ item.data.estado | claseEstado }}">{{ item.data.estado }}</span>
        </div>
        <div class="descripcion">{{ item.templateContent | safe }}</div>
        {% if item.data.documentos.length %}
        <div class="docs">
          {% for doc in item.data.documentos %}
          <a class="doc-enlace" href="{{ doc.archivo }}" target="_blank" rel="noopener">{{ doc.nombre }}</a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="sin-contenido">Actualmente no hay convocatorias de empleo abiertas. Las próximas ofertas se publicarán en esta página.</div>
    {% endif %}
  </div>
</section>
