<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {% endif %}{{ general.nombre }}</title>
  <meta name="description" content="{{ descripcion or general.eslogan }}">
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/estilos.css">
</head>
<body>
  {% if portada.aviso_activo and portada.aviso_texto %}
  <div class="aviso">{{ portada.aviso_texto }}</div>
  {% endif %}

  <header class="cabecera">
    <div class="cabecera-inner">
      <a class="logo" href="/" aria-label="Inicio — {{ general.nombre }}">
        <span class="logo-titulo">Discover Villajoyosa</span>
        <span class="logo-sub">Fundación de Turismo</span>
      </a>
      <button class="menu-boton" aria-label="Abrir menú" onclick="document.querySelector('.nav').classList.toggle('abierto')">
        <span></span><span></span><span></span>
      </button>
      <nav class="nav" aria-label="Navegación principal">
        <a href="/" {% if page.url == "/" %}class="activo"{% endif %}>Inicio</a>
        <a href="/fundacion/" {% if "/fundacion/" in page.url %}class="activo"{% endif %}>La Fundación</a>
        <a href="/noticias/" {% if "/noticias/" in page.url %}class="activo"{% endif %}>Actualidad</a>
        <a href="/transparencia/" {% if "/transparencia/" in page.url %}class="activo"{% endif %}>Transparencia</a>
        <a href="/contacto/" class="nav-destacado {% if '/contacto/' in page.url %}activo{% endif %}">Contacto</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="pie">
    <div class="pie-inner">
      <div class="pie-marca">
        <span class="logo-titulo">Discover Villajoyosa</span>
        <span class="logo-sub">Fundación de Turismo</span>
        <p>{{ general.eslogan }}.<br>{{ general.direccion }}</p>
      </div>
      <div>
        <h4>La web</h4>
        <ul>
          <li><a href="/fundacion/">La Fundación</a></li>
          <li><a href="/noticias/">Actualidad</a></li>
          <li><a href="/transparencia/">Portal de transparencia</a></li>
          <li><a href="/contacto/">Contacto</a></li>
        </ul>
      </div>
      <div>
        <h4>Contacto</h4>
        <ul>
          {% if general.email %}<li><a href="mailto:{{ general.email }}">{{ general.email }}</a></li>{% endif %}
          {% if general.telefono %}<li><a href="tel:{{ general.telefono | replace(' ', '') }}">{{ general.telefono }}</a></li>{% endif %}
          {% if general.instagram %}<li><a href="{{ general.instagram }}" rel="noopener">Instagram</a></li>{% endif %}
          {% if general.facebook %}<li><a href="{{ general.facebook }}" rel="noopener">Facebook</a></li>{% endif %}
          {% if general.twitter %}<li><a href="{{ general.twitter }}" rel="noopener">X (Twitter)</a></li>{% endif %}
          {% if general.youtube %}<li><a href="{{ general.youtube }}" rel="noopener">YouTube</a></li>{% endif %}
        </ul>
      </div>
    </div>
    <div class="pie-legal">
      © {% year %} {{ general.nombre }} · <a href="/aviso-legal/">Aviso legal</a> · <a href="/politica-privacidad/">Privacidad</a> · <a href="/admin/">Acceso editores</a>
    </div>
  </footer>

</body>
</html>
